  "keyFeatures": [
    "Product catalog with search and filtering by category",
    "Shopping cart with localStorage persistence",
    "WhatsApp integration for orders and customer service",
    "Calendar booking system for construction services",
    "Real-time business hours tracking",
    "Delivery mode toggle (pickup vs. delivery)",
    "Responsive image carousel for project showcase",
    "Dual-brand experience (Corralón and Construcción)"
  ],
  "publicApiSurface": [
    "initCatalogAndCart() - Initialize product catalog and shopping cart",
    "initProjectsSlider() - Initialize project showcase carousel",
    "initCleaningCalendar() - Initialize service booking calendar",
    "initBusinessStatus() - Check and display business hours status",
    "renderCatalog() - Render product catalog with filters",
    "renderCart() - Display shopping cart items",
    "addToCart() - Add product to cart",
    "buildWhatsappMessage() - Generate WhatsApp order message",
    "productCategories[] - Product catalog data structure",
    "CART_STORAGE_KEY - localStorage key for cart persistence",
    "DELIVERY_MODE_STORAGE_KEY - localStorage key for delivery preference"
  ]
